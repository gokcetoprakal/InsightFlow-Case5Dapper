@*Default Head*@

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>InsightFlow | Premium Analytics</title>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&amp;family=Manrope:wght@600;700;800&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                      "on-tertiary-fixed": "#1a1c1f",
                      "surface-container-lowest": "#ffffff",
                      "on-surface": "#1a1b1f",
                      "surface-variant": "#e3e2e7",
                      "primary-fixed-dim": "#adc6ff",
                      "inverse-on-surface": "#f1f0f5",
                      "outline": "#717786",
                      "error-container": "#ffdad6",
                      "on-secondary-fixed": "#1b1b1d",
                      "on-background": "#1a1b1f",
                      "on-secondary": "#ffffff",
                      "surface-container": "#eeedf3",
                      "on-secondary-container": "#636264",
                      "surface-bright": "#faf9fe",
                      "outline-variant": "#c1c6d7",
                      "tertiary-fixed-dim": "#c6c6cb",
                      "on-primary-fixed-variant": "#004493",
                      "background": "#faf9fe",
                      "surface-dim": "#dad9df",
                      "primary": "#0058bc",
                      "primary-container": "#0070eb",
                      "secondary-fixed": "#e4e2e4",
                      "on-secondary-fixed-variant": "#474649",
                      "surface-container-high": "#e9e7ed",
                      "inverse-surface": "#2f3034",
                      "error": "#ba1a1a",
                      "surface-container-low": "#f4f3f8",
                      "secondary-fixed-dim": "#c8c6c8",
                      "on-tertiary-container": "#fdfcff",
                      "secondary-container": "#e2dfe1",
                      "surface-container-highest": "#e3e2e7",
                      "on-tertiary": "#ffffff",
                      "on-surface-variant": "#414755",
                      "tertiary-fixed": "#e2e2e7",
                      "on-tertiary-fixed-variant": "#45474b",
                      "surface-tint": "#005bc1",
                      "tertiary": "#5a5c60",
                      "tertiary-container": "#737479",
                      "on-error": "#ffffff",
                      "on-error-container": "#93000a",
                      "on-primary-container": "#fefcff",
                      "primary-fixed": "#d8e2ff",
                      "inverse-primary": "#adc6ff",
                      "on-primary-fixed": "#001a41",
                      "secondary": "#5f5e60",
                      "on-primary": "#ffffff",
                      "surface": "#faf9fe"
              },
              "borderRadius": {
                      "DEFAULT": "0.25rem",
                      "lg": "0.5rem",
                      "xl": "0.75rem",
                      "full": "9999px",
                      "card": "20px"
              },
              "spacing": {
                      "stack-sm": "8px",
                      "unit": "4px",
                      "margin": "32px",
                      "stack-md": "16px",
                      "gutter": "24px",
                      "container-max": "1440px",
                      "stack-lg": "24px"
              },
              "fontFamily": {
                      "stats-display": ["Manrope"],
                      "h2": ["Manrope"],
                      "h1": ["Manrope"],
                      "h3": ["Manrope"],
                      "body-lg": ["Inter"],
                      "label-caps": ["Inter"],
                      "body-md": ["Inter"]
              },
              "fontSize": {
                      "stats-display": ["48px", {"lineHeight": "1.0", "letterSpacing": "-0.03em", "fontWeight": "700"}],
                      "h2": ["24px", {"lineHeight": "1.3", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                      "h1": ["32px", {"lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                      "h3": ["20px", {"lineHeight": "1.4", "letterSpacing": "0", "fontWeight": "600"}],
                      "body-lg": ["16px", {"lineHeight": "1.6", "letterSpacing": "0", "fontWeight": "400"}],
                      "label-caps": ["12px", {"lineHeight": "1.0", "letterSpacing": "0.05em", "fontWeight": "600"}],
                      "body-md": ["14px", {"lineHeight": "1.5", "letterSpacing": "0", "fontWeight": "400"}]
              }
            },
          },
        }
    </script>
    <style>
        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(229, 229, 234, 0.5);
            box-shadow: 0px 4px 20px rgba(0,0,0,0.05);
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        body {
            scroll-behavior: smooth;
        }
    </style>
</head>