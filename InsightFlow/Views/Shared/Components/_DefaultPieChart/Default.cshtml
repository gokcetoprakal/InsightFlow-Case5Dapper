@using InsightFlow.Dtos
@model IEnumerable<CategoryUsageDto>
@*Default Pie Chart*@

<section class="glass-card rounded-card p-8 space-y-6 bg-white/5 backdrop-blur-lg border border-white/10 shadow-2xl" id="category">
    @* Siyah ve Kalın Başlık *@
    <h3 class="text-2xl font-black text-slate-950 tracking-tight">Usage by Category</h3>

    <div class="relative flex justify-center items-center py-6">
        @* Klasik Pie Chart - CSS Conic Gradient ile *@
        @{
            // Grafik dilimlerini oluşturmak için derece hesaplama
            double currentDegree = 0;
            string gradientParts = "";
            var colors = new[] { "#10b981", "#f43f5e", "#f59e0b", "#6366f1" }; // Siyah, Yeşil, Kırmızı, Turuncu, Mor
            int colorIdx = 0;

            foreach (var item in Model)
            {
                double nextDegree = currentDegree + (item.Percentage * 3.6);
                gradientParts += $"{colors[colorIdx % colors.Length]} {currentDegree.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)}deg {nextDegree.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)}deg,";
                currentDegree = nextDegree;
                item.HexColor = colors[colorIdx % colors.Length]; // Listede kullanmak için rengi sakla
                colorIdx++;
            }
            gradientParts = gradientParts.TrimEnd(',');
        }

        <div class="w-48 h-48 rounded-full shadow-2xl transition-transform duration-500 hover:scale-105"
             style="background: conic-gradient(@gradientParts); border: 2px solid rgba(0,0,0,0.1);">
        </div>
    </div>

    @* Lejant (Liste) Kısmı *@
    <div class="space-y-3">
        @foreach (var item in Model)
        {
            <div class="flex justify-between items-center group">
                <div class="flex items-center gap-3">
                    <span class="w-3 h-3 rounded-sm" style="background-color: @item.HexColor"></span>
                    @* Siyah ve Okunaklı Kategori İsmi *@
                    <span class="text-sm font-black text-slate-900 uppercase tracking-tighter group-hover:text-primary transition-colors">
                        @item.CategoryName
                    </span>
                </div>
                @* Yüzde Bilgisi *@
                <span class="text-sm font-black text-slate-950">%@item.Percentage.ToString("0")</span>
            </div>
        }
    </div>
</section>