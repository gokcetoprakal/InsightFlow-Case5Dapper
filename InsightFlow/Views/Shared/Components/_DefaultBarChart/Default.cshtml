@using InsightFlow.Dtos
@model List<ProductivityChartDto>

@{
    // Sayı formatı hatası (virgül/nokta) almamak için
    var culture = System.Globalization.CultureInfo.InvariantCulture;
    // ViewComponent içinde hesapladığın ortalamayı buradan alıyoruz
    double weeklyAvg = ViewBag.WeeklyAverage ?? 0;
}

<section class="lg:col-span-2 glass-card rounded-card p-8 space-y-6 bg-white/5 backdrop-blur-lg border border-white/10 shadow-2xl">
    <div class="flex justify-between items-end">
        <div>
            @* BAŞLIK: Tam siyah ve çok kalın *@
            <h3 class="text-2xl font-black text-slate-950 tracking-tight">Productivity Analysis</h3>
            @* ALT BAŞLIK: Koyu gri/siyah tonu *@
            <p class="text-sm text-slate-800 font-bold">Haftalık Ortalama: <span class="text-primary">%@weeklyAvg.ToString("0")</span></p>
        </div>
        <div class="bg-primary/10 px-3 py-1 rounded-full border border-primary/20">
            <span class="text-[10px] font-bold text-primary uppercase tracking-tighter">Live Performance</span>
        </div>
    </div>

    <div class="h-64 flex items-end justify-between gap-4 border-b-2 border-slate-900 pb-8 pl-4 relative">

        @* Ortalama Çizgisi (Senin ViewBag.WeeklyAverage değerine göre) *@
        <div class="absolute w-full border-t-2 border-dashed border-primary/30 z-0 transition-all duration-1000"
             style="bottom: calc(@(weeklyAvg.ToString("0.00", culture))% + 32px);">
            <span class="absolute -left-12 -top-2.5 text-[10px] font-black text-primary/60 tracking-tighter">ORTALAMA</span>
        </div>

        @if (Model != null)
        {
            foreach (var item in Model)
            {
                // Ortalamanın üstünde mi altında mı kontrolü
                bool isAbove = item.AvgProductivity >= weeklyAvg;
                string barColor = isAbove ? "bg-emerald-500" : "bg-rose-500";
                string glow = isAbove ? "shadow-[0_0_20px_rgba(16,185,129,0.3)]" : "shadow-[0_0_15px_rgba(244,63,94,0.15)]";

                <div class="flex-1 flex flex-col items-center gap-4 group h-full justify-end relative z-10">

                    @* Bar *@
                    <div class="w-full relative flex items-end justify-center h-full">
                        <div class="w-3/4 @barColor @glow rounded-t-sm transition-all duration-500 group-hover:scale-x-110 group-hover:brightness-110"
                             style="height: @(item.AvgProductivity.ToString("0.00", culture))%;">

                            @* Hover Değer *@
                            <div class="absolute -top-7 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-all">
                                <span class="text-[11px] font-black @(isAbove ? "text-emerald-400" : "text-rose-400")">
                                    %@item.AvgProductivity
                                </span>
                            </div>
                        </div>
                    </div>

                    @* GÜN YAZISI - Siyah ve Belirgin *@
                    <span class="text-[13px] font-black text-slate-950 uppercase tracking-[0.15em]">
                        @(item.DayOfWeek.Length > 2 ? item.DayOfWeek.Substring(0, 3) : item.DayOfWeek)
                    </span>
                </div>
            }
        }
    </div>
</section>