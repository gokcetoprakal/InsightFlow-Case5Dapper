@*Default Banner*@

<section class="relative mb-10 overflow-hidden rounded-3xl bg-slate-950 p-10 shadow-2xl">
    <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-primary/20 blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 h-64 w-64 rounded-full bg-indigo-500/10 blur-3xl"></div>

    <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="max-w-2xl space-y-4">
            @* Badge *@
            <span class="inline-block rounded-full bg-primary/20 px-4 py-1 text-xs font-black uppercase tracking-widest text-primary">
                v2.0 Live Analysis
            </span>

            @* Ana Başlık *@
            <h1 class="text-4xl md:text-5xl font-black text-white leading-tight tracking-tighter">
                Decode Your <span class="text-primary">Productivity</span> <br />
                with InsightFlow.
            </h1>

            @* Açıklama *@
            <p class="text-lg text-slate-400 font-medium leading-relaxed">
                InsightFlow, ekran süresi ve uyku düzeni arasındaki karmaşık bağı analiz ederek yaşam kalitenizi optimize eder.
                <span class="text-white">500.000+</span> veri noktasıyla, alışkanlıklarınızın verimliliğinizi nasıl şekillendirdiğini keşfedin.
            </p>
        </div>

        @* Sağ Taraf - İstatistik Özeti (Görsel Zenginlik) *@
        <div class="grid grid-cols-2 gap-4 w-full md:w-auto">
            <div class="glass-card flex flex-col items-center justify-center rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-md">
                <span class="text-3xl font-black text-white">500K+</span>
                <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Processed Data</span>
            </div>
            <div class="glass-card flex flex-col items-center justify-center rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-md">
                <span class="text-3xl font-black text-primary">24/7</span>
                <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Real-time Sync</span>
            </div>
        </div>
    </div>
</section>