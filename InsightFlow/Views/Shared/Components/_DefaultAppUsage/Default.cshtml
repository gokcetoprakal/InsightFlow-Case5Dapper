@using InsightFlow.Dtos
@model IEnumerable<AppUsageDto>
@*Default App Usage*@

<section class="glass-card rounded-card p-8 space-y-6 bg-white/5 backdrop-blur-lg border border-white/10 shadow-2xl" id="apps">
    @* Siyah ve Keskin Başlık *@
    <h3 class="text-2xl font-black text-slate-950 tracking-tight">App Usage Distribution</h3>

    <div class="space-y-6">
        @foreach (var item in Model)
        {
            @* Kategoriye göre bar rengi seçimi (Opsiyonel) *@
            string barColor = item.CategoryName == "Social" ? "bg-rose-500" : "bg-primary";

            <div class="space-y-2 group">
                <div class="flex justify-between items-end">
                    @* Uygulama Adı - Siyah ve Kalın *@
                    <span class="text-sm font-black text-slate-900 uppercase tracking-tighter group-hover:text-primary transition-colors">
                        @item.AppName
                    </span>
                    @* Süre Bilgisi *@
                    <span class="text-xs font-bold text-slate-600">@item.FormattedTime</span>
                </div>

                @* Progress Bar Arka Plan *@
                <div class="h-2 w-full bg-slate-900/10 rounded-full overflow-hidden">
                    @* Dinamik Doluluk *@
                    <div class="h-full @barColor transition-all duration-1000 ease-out rounded-full shadow-[0_0_10px_rgba(0,0,0,0.1)]"
                         style="width: @item.UsagePercentage.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%">
                    </div>
                </div>
            </div>
        }
    </div>
</section>